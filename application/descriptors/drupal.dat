SOURCECODE_MD5:5c8bc612859d7026178ea5463cc7c889
SOURCECODE_SHA1:1b0b11114167d52aa01ce512e5508dea74bc9ffd
SOURCECODE_SHA256:7de44170b531124d54017860aebbc0d471495bbff9cf6b787026c0284e065edc

INTERACTIVE_APPLICATION_INSTALL:no

INDIVIDUAL_SETTING:username=XXXXAPPLICATION_USERNAMEXXXX
INDIVIDUAL_SETTING:password=XXXXAPPLICATION_PASSWORDXXXX
INDIVIDUAL_SETTING:database=XXXXAPPLICATION_DATABASEXXXX
INDIVIDUAL_SETTING:host=placeholder
INDIVIDUAL_SETTING:port=placeholder
INDIVIDUAL_SETTING:driver=XXXXAPPLICATION_DB_TYPEXXXX
INDIVIDUAL_SETTING:prefix=placeholder

ADDITIONAL_SETTING:$settings['package_manager_composer_path'] = '/usr/local/bin/composer';
ADDITIONAL_SETTING:$settings['package_manager_rsync_path'] = '/usr/bin/rsync';
ADDITIONAL_SETTING:$settings['testing_package_manager'] = TRUE;
ADDITIONAL_SETTING:$config["system.logging"]["error_level"] = "error";
ADDITIONAL_SETTING:$settings["trusted_host_patterns"] = [ ".*" ];
ADDITIONAL_SETTING:$settings["config_sync_directory"] = "/var/www/html/sites/default";
ADDITIONAL_SETTING:$config["system.performance"]["css"]["preprocess"] = FALSE;
ADDITIONAL_SETTING:$config["system.performance"]["js"]["preprocess"] = FALSE;
ADDITIONAL_SETTING:$settings["file_private_path"] = $app_root . "/../private";





