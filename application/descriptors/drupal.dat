APPLICATION_TYPE:cms

APPLICATION_USERNAME:webmaster (set this to something harder to guess or specific to your site in this file or directly in the database)
APPLICATION_PASSWORD:mnbcxz098321QQQZZZ (change this using the GUI system as the first thing you do once drupal is installed non-interactively)

#Application Directories structure
DIRECTORIES_TO_CREATE:logs:tmp:cache:sites/default/files

DIRECTORIES_TO_CREATE_ABSOLUTE:/var/www/private

#Application structure rudimentary integrity check
#APPLICATION_INTEGRITY_DIRECTORIES:core:modules:profiles:recipes:sites:themes:vendor
#APPLICATION_INTEGRITY_FILES:autoload.php:index.php:update.php

#SOURCECODE_URL:ftp.drupal.org/files/projects/drupal-11.3.5.zip
