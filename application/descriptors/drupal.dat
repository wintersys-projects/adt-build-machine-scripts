#Application Type (only uncomment one of these 2)

# 1. To install drupal uncomment and comment drupal cms below
#APPLICATION_TYPE:drupal

#Furthermore tell us what version of drupal you want to install
#Uncommented, this will install the latest version
DRUPAL_VERSION:drupal/recommended-project

#To install a specific version do this instead
#DRUPAL_VERSION:drupal/recommended-project:11.3.0

#To install an alpha or beta or rc
#DRUPAL_VERSION:drupal/recommended-project:^11@alpha
#DRUPAL_VERSION:drupal/recommended-project:^11@beta
#DRUPAL_VERSION:drupal/recommended-project:^11@rc

#2. To install drupal CMS
# To install drupal CMS uncomment and comment drupal above
APPLICATION_TYPE:cms

#Furthermore tell us what version of drupal cmsyou want to install
#Uncommented, this will install the latest version
#CMS_VERSION:drupal/cms

#To install a specific version do this instead
DRUPAL_VERSION:drupal/cms:2.0.4

#To install an alpha or beta or rc
#DRUPAL_VERSION:drupal/cms:^2.1@alpha
#DRUPAL_VERSION:drupal/cms:^2.1@beta
#DRUPAL_VERSION:drupal/cms:^2.1@rc


APPLICATION_USERNAME:webmaster (set this to something harder to guess or specific to your site in this file or directly in the database)
APPLICATION_PASSWORD:mnbcxz098321QQQZZZ (change this using the GUI system as the first thing you do once drupal is installed non-interactively)

#Application Directories structure
DIRECTORIES_TO_CREATE:logs:tmp:cache:sites/default/files:private

#Application structure rudimentary integrity check
APPLICATION_INTEGRITY_DIRECTORIES:core:modules:profiles:recipes:sites:themes:vendor
APPLICATION_INTEGRITY_FILES:autoload.php:index.php:update.php

