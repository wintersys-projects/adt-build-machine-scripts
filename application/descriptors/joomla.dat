#INTERACTIVE_APPLICATION_INSTALL="no"

#Database

INDIVIDUAL_SETTING:user="XXXXAPPLICATION_USERNAMEXXXX"
INDIVIDUAL_SETTING:password="XXXXAPPLICATION_PASSWORDXXXX"
INDIVIDUAL_SETTING:db="XXXXAPPLICATION_DATABASEXXXX"
INDIVIDUAL_SETTING:host="placeholder"
INDIVIDUAL_SETTING:type="XXXXAPPLICATION_DB_TYPEXXXX"
INDIVIDUAL_SETTING:dbprefix="placeholder"


#Mailer
INDIVIDUAL_SETTING:mailer="XXXXMAILERXXXX"
INDIVIDUAL_SETTING:from_email="XXXXMAIL_FROMXXXX"
INDIVIDUAL_SETTING:reply_to="XXXXREPLY_TOXXXX"
INDIVIDUAL_SETTING:from_name="XXXXFROM_NAMEXXXX"
INDIVIDUAL_SETTING:reply_to_name="XXXXREPLY_TO_NAMEXXXX"
INDIVIDUAL_SETTING:smtp_auth=1
INDIVIDUAL_SETTING:smtp_username="XXXXSMTP_USERXXXX"
INDIVIDUAL_SETTING:smtp_password="XXXXSMTP_PASSXXXX"
INDIVIDUAL_SETTING:smtp_secure="tls"
INDIVIDUAL_SETTING:smtp_port="XXXXSMTP_PORTXXXX"
INDIVIDUAL_SETTING:smtp_host="XXXXSMTP_HOSTXXXX"

#Hardcoded overrides
INDIVIDUAL_SETTING:secret="placeholder"
INDIVIDUAL_SETTING:cachetime=30
INDIVIDUAL_SETTING:cache_handler="file"
INDIVIDUAL_SETTING:caching=1
INDIVIDUAL_SETTING:sef=0
INDIVIDUAL_SETTING:sef_suffix=0
INDIVIDUAL_SETTING:sef_rewrite=0
INDIVIDUAL_SETTING:gzip=1
INDIVIDUAL_SETTING:force_ssl=2
INDIVIDUAL_SETTING:shared_session=0
INDIVIDUAL_SETTING:tmp_path="/var/www/html/tmp"
INDIVIDUAL_SETTING:log_path="/var/www/html/logs"

